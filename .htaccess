# Disable directory browsing
Options -Indexes

# Set default index
DirectoryIndex index.html

# Block access to sensitive files and directories
<FilesMatch "\.(env|gitignore|gitattributes|md|py|pyc|db|sqlite|json|sample)$">
  Require all denied
</FilesMatch>

# Block dotfiles (.git, .claude, .env, etc.)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\.(?!well-known/) - [F,L]
</IfModule>

# Block backend and bot directories entirely
<IfModule mod_rewrite.c>
  RewriteRule ^backends/ - [F,L]
  RewriteRule ^discord-bot/ - [F,L]
  RewriteRule ^backup/ - [F,L]
  RewriteRule ^repo_stuff/ - [F,L]
  RewriteRule ^ref_data/ - [F,L]
</IfModule>

# Block specific sensitive files
<FilesMatch "^(config\.sample\.js|ecosystem\.config\.js|CLAUDE\.md|README\.md|composer\.json|package\.json)$">
  Require all denied
</FilesMatch>

# Allow JS files that the frontend needs
<FilesMatch "^(auth-common\.js|config\.js|analytics\.js)$">
  Require all granted
</FilesMatch>

# Clean URLs — visitors can drop the .html extension.
# The redirect rule canonicalises the URL ("/live.html" → "/live"); the
# rewrite rule transparently serves /<page>.html when /<page> is requested.
<IfModule mod_rewrite.c>
  # Skip /index.html (DirectoryIndex already handles the site root) so
  # links to "/" don't bounce. The negative lookahead matches anything
  # but index.html. The character class blocks dots/queries inside the
  # captured slug so /api/foo.json never matches.
  RewriteCond %{THE_REQUEST} \s/+(?!index\.html)([^./?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Internally rewrite /page → /page.html — but only when that .html file
  # actually exists on disk. Real files (config.js, styles.css, /assets/*)
  # and real directories pass through untouched.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([^/.]+)/?$ $1.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
