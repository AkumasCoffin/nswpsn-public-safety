# Disable directory browsing
Options -Indexes

# Set default index
DirectoryIndex index.html

# Block access to sensitive files and directories
<FilesMatch "\.(env|gitignore|gitattributes|md|py|pyc|db|sqlite|json|sample)$">
  Require all denied
</FilesMatch>

# Block dotfiles (.git, .env, etc.)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\.(?!well-known/) - [F,L]
</IfModule>

# Block backend and bot directories entirely
<IfModule mod_rewrite.c>
  RewriteRule ^backends/ - [F,L]
  RewriteRule ^discord-bot/ - [F,L]
  RewriteRule ^backup/ - [F,L]
  RewriteRule ^repo_stuff/ - [F,L]
  RewriteRule ^ref_data/ - [F,L]
</IfModule>

# Block specific sensitive files
<FilesMatch "^(config\.sample\.js|ecosystem\.config\.js|README\.md|composer\.json|package\.json)$">
  Require all denied
</FilesMatch>

# Allow JS files that the frontend needs
<FilesMatch "^(auth-common\.js|config\.js|analytics\.js)$">
  Require all granted
</FilesMatch>

# Cache policy: HTML, CSS and first-party JS must revalidate on every load
# (cheap 304s via ETag/Last-Modified). These files change often and a stale
# cached copy on one device against newer companions breaks pages — e.g. an
# old cached map.html + old map-editor-module.js kept serving a pre-fix
# editor build for days. Cloudflare honours origin Cache-Control, so this
# also stops the CDN pinning old builds once dev mode expires.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Allow the agency directory JSON files at the site root.
# Front-end fetches `/agency-data.json` and `/agency-extended.json` to populate
# the sidebar Agencies dropdown and the per-agency reference pages. The broader
# .json deny rule above protects everything else (package.json etc.).
<FilesMatch "^(agency-data|agency-extended)\.json$">
  Require all granted
</FilesMatch>

# Clean URLs — visitors can drop the .html extension.
# The redirect rule canonicalises the URL ("/live.html" → "/live"); the
# rewrite rule transparently serves /<page>.html when /<page> is requested.
<IfModule mod_rewrite.c>
  # Legacy standalone agency pages — retired in favour of the data-driven
  # agency template. 301 old bookmarks/search results to agency?slug=….
  # These must run before the clean-URL rules below.
  RewriteRule ^ambulance(\.html)?$ /agency?slug=nsw-ambulance [R=301,L]
  RewriteRule ^aviation(\.html)?$ /agency?slug=nsw-aviation [R=301,L]
  RewriteRule ^fire-and-rescue(\.html)?$ /agency?slug=fire-and-rescue-nsw [R=301,L]
  RewriteRule ^rural-fire-service(\.html)?$ /agency?slug=nsw-rural-fire-service [R=301,L]

  # Skip /index.html (DirectoryIndex already handles the site root) so
  # links to "/" don't bounce. The negative lookahead matches anything
  # but index.html. The character class blocks dots/queries inside the
  # captured slug so /api/foo.json never matches.
  RewriteCond %{THE_REQUEST} \s/+(?!index\.html)([^./?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Internally rewrite /page → /page.html — but only when that .html file
  # actually exists on disk. Real files (config.js, styles.css, /assets/*)
  # and real directories pass through untouched.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([^/.]+)/?$ $1.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
