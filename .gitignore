# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env
*.egg-info/
dist/
build/

# Node
node_modules/

# IDE / Editor / tooling state
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# Per-deployment frontend config — each environment maintains its own.
# Values inside are public-by-design (anon key + public API tag); ignored
# only so deployments don't clobber each other. Template lives in
# config.sample.js.
config.js

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*

# Database (uncomment if you don't want to track)
*.db

# Environment variables — both backend and bot keep their own .env locally.
.env
.env.local
.env.*.local

# Stale snapshot folder — kept locally for reference, not shipped.
backup/

# Internal docs are local-only by default — operator notes, probe scripts,
# raw flow diagrams. The Waze userscript IS checked in so contributors and
# self-hosters can grab the same code that powers the live ingest path.
docs/*
!docs/waze-userscript.user.js
!docs/waze-userscript-manual.user.js
!docs/uptime-kuma-monitors.md

# Radio unit reference data (local operator data, not for the public repo).
backends/reference/
