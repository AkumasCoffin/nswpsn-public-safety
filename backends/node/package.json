{
  "name": "nswpsn-api-node",
  "version": "0.1.0",
  "private": true,
  "description": "Node/TypeScript rewrite of the NSW PSN backend API. See ../../docs/migration-plan if it exists, or the W1-W9 plan for context.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file-if-exists=../.env watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "prestart": "npm run build",
    "start": "node --env-file-if-exists=../.env dist/index.js",
    "deploy": "bash scripts/deploy.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "capture-fixtures": "tsx --env-file-if-exists=../.env scripts/capture-fixtures.ts",
    "ntfy-test": "tsx --env-file-if-exists=../.env scripts/test-ntfy-detection.ts",
    "migrate": "tsx --env-file-if-exists=../.env src/db/migrate.ts",
    "migrate-history": "node --env-file-if-exists=../.env scripts/migrate-history.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "dictionary-en-au": "^3.0.0",
    "fast-xml-parser": "^5.9.3",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "nspell": "^2.1.5",
    "pg": "^8.22.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.61.1",
    "undici": "^7.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/nspell": "^2.1.6",
    "@types/pg": "^8.11.10",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
