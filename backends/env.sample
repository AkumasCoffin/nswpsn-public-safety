# NSW PSN External API Proxy - Environment Configuration
# Copy this file to .env and fill in your values.

# =============================================================================
# DATABASES (PostgreSQL)
# =============================================================================

# Main NSW PSN DB — cache, stats, history, summaries.
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://nswpsn:yourpassword@localhost:5432/nswpsn

# rdio-scanner DB — read-only access is sufficient.
# Leave unset to disable the radio-scanner summary feature.
# RDIO_DATABASE_URL=postgresql://rdio:password@10.1.0.110:5432/rdio_scanner

# =============================================================================
# API KEYS
# =============================================================================

# NSWPSN API key for /api endpoints (used by clients to authenticate)
NSWPSN_API_KEY=your_api_key_here

# Pagermon API key (optional - only if your Pagermon requires auth)
# PAGERMON_API_KEY=

# =============================================================================
# GEMINI (radio scanner summaries)
# =============================================================================

# API key from https://aistudio.google.com/app/apikey (free tier is fine).
# Supports multiple comma-separated keys to spread load and survive per-key
# rate limits — the service rotates and rolls over to the next key on a 429.
# Leave unset to disable summary generation.
# GEMINI_API_KEY=AIza...keyA,AIza...keyB

# Model used for both hourly and daily summaries. Gemini is called via its
# OpenAI-compatible endpoint, so any model ID Google documents works here.
# Defaults to gemini-2.5-flash. (gemini-2.0-flash is only available to
# accounts that already had access — new keys must use 2.5.)
# Other options: gemini-2.5-flash-lite (cheaper, smaller), gemini-2.5-pro (slower, smarter).
# LLM_MODEL=gemini-2.5-flash

# Fallback model, used ONLY when LLM_MODEL exhausts its retries (sustained 503
# overload or all keys 429'd). A lighter model has its own capacity pool, so it
# usually answers when the primary is overloaded — this keeps summaries flowing
# through Gemini's flaky periods. Matters most if LLM_MODEL is gemini-2.5-pro,
# which is more contended. Set empty to disable; ignored if equal to LLM_MODEL.
# LLM_MODEL_FALLBACK=gemini-2.5-flash-lite

# IANA timezone for hourly/daily bucket boundaries (default: Australia/Sydney)
# SUMMARY_TZ=Australia/Sydney

# On startup, backfill the previous completed hour's summary if it's missing
# (e.g. the process was down at its HH:55 fire). Idempotent — only calls the
# LLM when the row is genuinely absent. Default: on. Set to false to disable.
# NODE_RDIO_CATCHUP=false

# In-process hourly summary scheduler (fires at HH:55 local). Default: on.
# Set to false on read-only mirrors so two schedulers don't double-spend
# Gemini quota.
# NODE_RDIO_SCHEDULER=true

# Override prompt file path. Default:
#   backends/prompts/rdio_hourly.txt
# Edits to that file apply on the NEXT summary run — no restart needed.
# RDIO_PROMPT_HOURLY=/absolute/path/to/custom_hourly_prompt.txt

# =============================================================================
# SUPABASE (required for user auth and incidents)
# =============================================================================

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (for backend admin operations like creating users)
# Find this in: Supabase Dashboard > Settings > API > service_role key
# WARNING: Keep this secret! Never expose in frontend code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# HS256 JWT signing secret — REQUIRED for editor/admin routes. Privileged
# endpoints verify the Supabase-issued JWT with this secret; when it's
# unset they return 503/401 and admins are effectively locked out.
# This is the LEGACY JWT secret (Supabase Dashboard > Settings > API >
# JWT Secret) — NOT the service-role key and NOT a JWT itself.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# =============================================================================
# ENDEAVOUR ENERGY (Supabase-based API)
# =============================================================================

# Endeavour Energy's public Supabase REST API
ENDEAVOUR_SUPABASE_URL=https://your-endeavour-project.supabase.co/rest/v1
ENDEAVOUR_SUPABASE_KEY=your_endeavour_anon_key_here

# =============================================================================
# EXTERNAL API URLS (optional - defaults shown)
# =============================================================================

# Pagermon API URL. NO default — when unset the pager source is disabled
# and /api/pager/hits returns an empty FeatureCollection.
# PAGERMON_URL=https://pager.example.com/api/messages

# --- Waze userscript ingest mode ---------------------------------------------
# Waze data is delivered exclusively by a Violentmonkey userscript running in a
# real browser, which POSTs georss payloads to /api/waze/ingest. There is no
# server-side scraper anymore. See docs/waze-userscript.md for full setup.
# WAZE_INGEST_KEY=generate-with-openssl-rand-hex-32
#
# How long to keep a bbox's ingest cached before it's pruned from the snapshot
# served by /api/waze/*. Needs to be greater than one full userscript rotation
# or the map will only show whatever was scraped in the last few minutes.
# Default 2400 (40 min) — 2x headroom over the userscript's ~16 min rotation.
# (/api/status flags the waze source stale after a fixed 900s without ingest.)
# WAZE_INGEST_MAX_AGE=2400

# =============================================================================
# DATA RETENTION (optional)
# =============================================================================

# DATA_RETENTION_DAYS=31          # How long to keep archive data (default 31)
# DATA_CLEANUP_INTERVAL_SECS=3600 # Cleanup loop interval in seconds
#                                 # (legacy alias DATA_CLEANUP_INTERVAL also accepted)

# =============================================================================
# RDIO INCIDENT ALERTS (ntfy push — optional)
# =============================================================================
# Detects bursts of radio traffic and pushes a ntfy notification. All off
# unless RDIO_INCIDENT_ALERTS_ENABLED=true and NTFY_* are set.
# RDIO_INCIDENT_ALERTS_ENABLED=false
# NTFY_BASE_URL=https://ntfy.example.com
# NTFY_TOPIC=nswpsn-major
# NTFY_TOKEN=tk_...
# RDIO_ALERT_POLL_SECS=20         # transcript poll cadence
# RDIO_BURST_WINDOW_MIN=5         # burst detection window (minutes)
# RDIO_BURST_THRESHOLD=10         # calls within the window to count as a burst
# RDIO_ALERT_REQUIRE_KEYWORD=true # burst must also match a keyword
# RDIO_ALERT_COOLDOWN_MIN=30      # per-incident re-alert cooldown
# RDIO_ALERT_KEYWORDS=...         # comma-separated (defaults built in)
# RDIO_ALERT_URGENT_KEYWORDS=...  # comma-separated (defaults built in)

# =============================================================================
# SOURCE KILL-SWITCHES (optional)
# =============================================================================
# Disable individual headless-browser / flaky sources without a code change.
# CENTRALWATCH_DISABLED=false
# MARINETRAFFIC_DISABLED=false
# AUSGRID_DISABLED=false

# =============================================================================
# POSTGRES / ARCHIVE OPS TUNING (optional — defaults are sensible)
# =============================================================================
# PG_POOL_MAX=40                        # read-pool connections
# PG_WRITER_POOL_MAX=8                  # archive writer pool connections
# PG_CONNECT_TIMEOUT_MS=10000
# ARCHIVE_FLUSH_INTERVAL=30             # archive flush cadence (seconds)
# ARCHIVE_MAX_ROWS_PER_TABLE_PER_FLUSH=4000
# ARCHIVE_DIMS_BACKFILL_DISABLED=false  # kill-switch for the one-shot dims backfill
# ARCHIVE_DIMS_BACKFILL_CHUNK=1000
# ARCHIVE_DIMS_BACKFILL_TIMEOUT=20s

# =============================================================================
# DASHBOARD (Discord-authenticated bot config UI)
# =============================================================================

# Postgres URL pointing at the Discord bot's DB (`nswpsn_bot`). When unset,
# all /api/dashboard/* endpoints return 503.
# Format: postgresql://user:password@host:port/nswpsn_bot
# BOT_DATA_DATABASE_URL=postgresql://nswpsn:yourpassword@localhost:5432/nswpsn_bot

# Discord application credentials — same app as the bot is fine, just add
# the redirect URI `{PUBLIC_BASE_URL}/api/dashboard/auth/callback` to its
# OAuth2 config in the Discord developer portal.
# DISCORD_CLIENT_ID=123456789012345678
# DISCORD_CLIENT_SECRET=your_client_secret

# Bot token used server-side to fetch guild channels/roles.
# DISCORD_BOT_TOKEN=your_bot_token_here

# Random secret used to HMAC-sign the dashboard session cookie. Rotate to
# invalidate all existing sessions. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# DASHBOARD_SESSION_SECRET=replace_with_random_string

# Public origin of the API itself (no trailing slash) — used to build the
# OAuth redirect URI Discord calls back to.
# PUBLIC_BASE_URL=https://api.nswpsn.example.com

# Where the dashboard HTML page is served — set this when the dashboard lives
# on a sibling subdomain from the API (e.g. dashboard at nswpsn.example.com,
# API at api.nswpsn.example.com). Falls back to PUBLIC_BASE_URL if unset.
# DASHBOARD_FRONTEND_URL=https://nswpsn.example.com

# Cookie domain for the dashboard session. Lets the dashboard subdomain and
# API subdomain share the cookie. Default: .forcequit.xyz — change to match
# your apex (leading dot included).
# DASHBOARD_COOKIE_DOMAIN=.example.com

# Comma-separated Discord user IDs that should see the Admin panel on the
# dashboard (gives access to /api/dashboard/admin/overview — global stats,
# per-guild preset counts, active sessions, broadcast composer, bot-action
# queue, source-health panel). Leave unset to disable the panel entirely.
# DASHBOARD_ADMIN_IDS=123456789012345678,234567890123456789

# =============================================================================
# NASA FIRMS fire hotspots (optional)
# =============================================================================
# Free key from https://firms.modaps.eosdis.nasa.gov/api/area/. Powers the
# fire-hotspot polygons on map.html / map-editor.html via /api/firms/hotspots.
# When unset the source stays empty and the layer just renders nothing.
# MAP_KEY=your_nasa_firms_key_here

# =============================================================================
# SERVER SETTINGS (optional)
# =============================================================================

# DEV_MODE=false            # Set to true for verbose logging
