# Discord Bot Token (Required)
# Get this from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Bot Developer (Required for dev commands)
# Your Discord User ID - Right click yourself > Copy User ID (enable Developer Mode first)
BOT_OWNER_ID=123456789012345678

# NSW PSN API Configuration
API_BASE_URL=http://localhost:8000
NSWPSN_API_KEY=your_api_key_here

# Database - PostgreSQL (preferred) or SQLite
# PostgreSQL connection URL (takes precedence over BOT_DB_PATH)
# BOT_DATABASE_URL=postgresql://user:password@localhost:5432/nswpsn_bot

# SQLite fallback - path to local file (used when BOT_DATABASE_URL not set)
# BOT_DB_PATH=C:\path\to\local\bot_config.db

# Logging Level (Optional - DEBUG for verbose output)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO