# =============================================================================
# NSW PSN Discord bot — environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# =============================================================================
# DISCORD CREDENTIALS
# =============================================================================

# Bot token — required.
# Get it from https://discord.com/developers/applications → your app → Bot.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord user ID for the bot owner. Gates `/dev clear-seen`, `/dev channel`,
# `/dev setup`. Right-click yourself in Discord with Developer Mode enabled
# to copy your user ID. Leave unset to disable those owner-only commands.
BOT_OWNER_ID=123456789012345678

# =============================================================================
# BACKEND API
# =============================================================================

# Where the bot polls upstream alerts and pulls radio summaries from.
# In production this is the Cloudflare-fronted backend (api.example.com);
# locally use http://localhost:8000.
API_BASE_URL=http://localhost:8000

# Identifier sent on every backend call as Authorization: Bearer <key>.
# Must match NSWPSN_API_KEY in the backend's .env.
NSWPSN_API_KEY=your_api_key_here

# Public origin where dashboard.html is served. The `/dashboard` slash
# command builds a deep link to this URL. No trailing slash.
# Default: https://nswpsn.forcequit.xyz
# PUBLIC_BASE_URL=https://nswpsn.example.com

# =============================================================================
# DATABASE
# =============================================================================

# Postgres connection URL for the bot's own DB (presets, mute state, fire log,
# action queue, seen-alerts, incident-messages). Required for production.
# Reserve a database for the bot — do NOT point this at the backend's DB.
# Format: postgresql://user:password@host:port/nswpsn_bot
BOT_DATABASE_URL=postgresql://user:password@localhost:5432/nswpsn_bot

# =============================================================================
# OPTIONAL
# =============================================================================

# IANA timezone used by `/ts` for date-range parsing.
# Default: Australia/Sydney
# SUMMARY_TZ=Australia/Sydney

# Logging level. Options: DEBUG, INFO, WARNING, ERROR. Default: INFO.
# LOG_LEVEL=INFO
